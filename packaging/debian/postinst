#!/bin/sh
set -e

if [ "${1:-}" = "configure" ]; then
  cat <<'MESSAGE'
ArduPilot swarm management tools are installed.

Run the host installer as the account that will own and run ArduPilot:

  ardupilot-swarm-install

The installer builds MAVLink Router and ArduPilot from their upstream Git
repositories, installs the runtime scripts and systemd units, and configures
the local MAVLink Router endpoint.
MESSAGE
fi

exit 0
